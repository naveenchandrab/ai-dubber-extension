{
  "manifest_version": 3,
  "name": "AI Dubber",
  "description": "Translate and dub OTT video subtitles with secure backend translation and TTS.",
  "version": "1.1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.netflix.com/*",
    "https://www.primevideo.com/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Dubber",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*", "https://www.primevideo.com/*"],
      "js": [
        "utils.js",
        "cacheManager.js",
        "subtitleExtractor.js",
        "translator.js",
        "ttsService.js",
        "audioEngine.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
